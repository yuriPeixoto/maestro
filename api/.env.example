# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

# Redis (Memurai on Windows or Redis on Linux)
MAESTRO_REDIS_URL=redis://localhost:6379

# ClickHouse
MAESTRO_CLICKHOUSE_HOST=localhost
MAESTRO_CLICKHOUSE_PORT=8123
MAESTRO_CLICKHOUSE_USER=default
MAESTRO_CLICKHOUSE_PASSWORD=
MAESTRO_CLICKHOUSE_DATABASE=maestro

# Optional tuning (defaults shown)
# MAESTRO_OFFLINE_THRESHOLD_SECONDS=90
# MAESTRO_CONSUMER_BATCH_SIZE=500